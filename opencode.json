{
  "$schema": "https://opencode.ai/config.json",
  "model": "zhipu/glm-5",
  "provider": {
    "zhipu": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "智谱 GLM",
      "options": {
        "baseURL": "https://open.bigmodel.cn/api/paas/v4",
        "apiKey": "{env:ZHIPUAI_API_KEY}"
      },
      "models": {
        "glm-5": {
          "name": "GLM-5"
        },
        "glm-4-plus": {
          "name": "GLM-4-Plus"
        }
      }
    }
  },
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "write": "allow",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "skill": {
      "*": "allow"
    }
  }
}
